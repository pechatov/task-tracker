APP_BASE_URL=https://task-tracker.example.com
APP_PORT=3000

POSTGRES_DB=task_tracker
POSTGRES_USER=task_tracker
POSTGRES_PASSWORD=replace-with-long-random-postgres-password
DATABASE_URL=postgres://task_tracker:replace-with-long-random-postgres-password@postgres:5432/task_tracker

# Generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY=replace-with-base64-32-byte-key
APP_ENCRYPTION_KEY_ID=production

# Generate with: openssl rand -base64 48
AUTH_SESSION_SECRET=replace-with-at-least-32-characters

CALENDAR_SYNC_PAST_DAYS=365
CALENDAR_SYNC_FUTURE_DAYS=90
CALENDAR_SYNC_POLL_SECONDS=600

# Optional. Required only for Google Calendar OAuth.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional. Required only for Microsoft 365 Calendar OAuth.
# Register this redirect URI in Entra ID:
# https://task-tracker.example.com/api/calendar/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Optional. Required only for local calendar import bridges.
LOCAL_CALENDAR_IMPORT_TOKEN=
LOCAL_CALENDAR_IMPORT_USER_EMAIL=

# Used by Docker Compose on the deployment host.
TASK_TRACKER_IMAGE=ghcr.io/owner/task-tracker
TASK_TRACKER_TAG=main
