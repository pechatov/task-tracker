APP_BASE_URL=http://localhost:3000
DATABASE_URL=postgres://task_tracker:task_tracker@localhost:5432/task_tracker

# Generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY=replace-with-base64-32-byte-key
APP_ENCRYPTION_KEY_ID=local-dev

# Generate a long random string for session signing.
AUTH_SESSION_SECRET=replace-with-at-least-32-characters

CALENDAR_SYNC_PAST_DAYS=365
CALENDAR_SYNC_FUTURE_DAYS=90
CALENDAR_SYNC_POLL_SECONDS=600

# Optional. Required only for Google Calendar OAuth.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional. Required only for Microsoft 365 Calendar OAuth.
# Register this redirect URI in Entra ID:
# http://localhost:3000/api/calendar/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Optional. Required only for local calendar import bridges.
LOCAL_CALENDAR_IMPORT_TOKEN=
LOCAL_CALENDAR_IMPORT_USER_EMAIL=

# Local workaround for Outlook Web without app registration.
# Stores a browser profile under .local/ and reuses the interactive login session.
OUTLOOK_BROWSER_USER_EMAIL=
OUTLOOK_BROWSER_CALENDAR_URL=https://outlook.office.com/calendar/
OUTLOOK_BROWSER_SYNC_SECONDS=600
OUTLOOK_BROWSER_HEADLESS=0
OUTLOOK_BROWSER_PROFILE_DIR=.local/outlook-browser-profile
